    "title": "帮助中心",
    "subtitle": "QRSYS个事体统统箇里寻",
    "searchPlaceholder": "寻寻看...",
    "categories": {
      "all": "全部",
      "general": "基本事体",
      "auth": "账号搭安全",
      "dashboard": "总台哪亨用",
      "settings": "配置设置",
      "guestExperience": "客人体验",
      "qrPlacements": "QR 放置位置",
      "hierarchy": "角色和权限"
    },
    "sections": {
      "philosophy": {
        "title": "系统想法搭目标",
        "content": "QR SYS 是一个全面个酒店服务管理系统，目标是让客人搭员工之间沟通更快捷。阿拉想让酒店体验数字化，让客人扫二维码就能叫服务，弗用打热线或者跑前台。迭个能提高效率，减少等待辰光，还能给管理层提供实时数据分析。"
      },
      "registration": {
        "title": "注册搭激活",
        "content": "开始前，拉首页点“注册新酒店”。侬要写酒店基础信息，比如名字、时区搭钞票单位。要保证主管邮件是灵个，因为要发激活信。验证好之后，侬就能进总台配置服务勒。"
      },
      "login": {
        "title": "登录",
        "content": "用注册个邮件搭密码登录。若是员工，主管会给侬账号。填信息前要确认弗是别扭网页。"
      },
      "forgotPassword": {
        "title": "密码忘勒？",
        "content": "忘脱勒就拉登录页点“忘记密码”。写好邮件，阿拉发重设链接。注意：只有大主管能自家重设，普通员工要找主管协助。"
      },
      "orders": {
        "title": "管单子",
        "content": "单子页面是系统核心。客整个单子统统拉拉箇里。单子有三种状态：“全新”、“做紧”搭“好勒”。侬也能撤脱单子。有新单子阿拉会实时提醒侬。"
      },
      "services": {
        "title": "主服务搭细项",
        "content": "服务分主项（比如扫除、吃老酒）搭细项（比如房间打扫、递毛巾）。侬好设服务辰光、写介绍、传图画，等菜单更好看。"
      },
      "items": {
        "title": "具体物事管理",
        "content": "东西是指某个服务里个具体事体（比如餐饮里个“俱乐部三明治”）。侬好定价格、写介绍。要是没货勒，标成不可用，客人就看不见勒。"
      },
      "rooms": {
        "title": "房间搭二维码",
        "content": "每个房间都有自家个二维码。侬好加房间、分楼层搭房型。房间弄好勒，就能下载或者打印码贴拉房里。"
      },
      "employees": {
        "title": "员工搭权限",
        "content": "员工页管团队。分三种人：\n1. 酒店主管：全部事体统统好管。\n2. 部门主管：管具体部门个东西搭员工。\n3. 服务员工：管接单搭做单。"
      },
      "reports": {
        "title": "报告搭分析",
        "content": "看报告看酒店表现如何。看总入账、平均用时搭热门服务。好按日期选来看。"
      },
      "settings": {
        "title": "设置搭本地化",
        "content": "设置里好改 Logo、主副语言、时区搭钞票。改邮件要重新验证。换勒副语言，别忘记改服务搭东西个翻译。"
      },
